import java.util.*;
class patterns{
public static void main(String args[]){
  System.out.println("enter no of rows:");
  Scanner in =new Scanner(System.in);
  int n=in.nextInt();
 for(int i=0;i<n;i++){
    for(int j=i;j<n;j++)
{System.out.print("*");}
  System.out.print("\n");
 }
 
}
}
