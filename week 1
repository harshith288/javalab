import java.util.*;
class unique{
public static void main(String args[]){
 int[] arr={1,2,3,4,3,2,1};
 int digit=arr[0];
 for(int i=1;i<arr.length;i++){
   digit^=arr[i];
}
System.out.print(digit);
}
}
